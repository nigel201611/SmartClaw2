{
  "name": "smartclaw",
  "version": "1.0.0",
  "description": "AI-powered desktop chatbot based on OpenClaw",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "electron": "^28.0.0"
  },
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "dev:agent": "npm run dev --workspace=apps/agent",
    "build": "npm run build --workspaces",
    "build:win": "npm run build:win --workspace=apps/desktop",
    "build:mac": "npm run build:mac --workspace=apps/desktop",
    "build:linux": "npm run build:linux --workspace=apps/desktop",
    "build:all": "npm run build:all --workspace=apps/desktop",
    "start": "npm run start --workspace=apps/desktop",
    "smartclaw": "smartclaw",
    "smartclaw:init": "smartclaw init",
    "smartclaw:config": "smartclaw config",
    "smartclaw:validate": "smartclaw validate",
    "smartclaw:health": "smartclaw health",
    "postinstall": "echo 'Installation complete! Run npm run build manually if you want to build the desktop app.'"
  },
  "keywords": [
    "chatbot",
    "agent",
    "openclaw",
    "desktop",
    "electron",
    "matrix",
    "auto-config",
    "ai"
  ],
  "author": "Nigel Luo",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nigel201611/SmartClaw.git"
  },
  "bugs": {
    "url": "https://github.com/nigel201611/SmartClaw/issues"
  },
  "homepage": "https://github.com/nigel201611/SmartClaw#readme"
}
