// .vscode/tasks.json
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start-vite",
      "type": "shell",
      "command": "yarn dev:renderer",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "ready in .*ms"
        }
      }
    }
  ]
}
